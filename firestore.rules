rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function: check if user is authenticated and approved
    function isApproved() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == "approved";
    }

    // Helper function: check if user is admin
    function isAdmin() {
      return isApproved() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Helper function: check if user has edit rights (admin, spoc, hod)
    function canEdit() {
      return isApproved() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "spoc", "hod"];
    }

    // Users collection
    match /users/{userId} {
      // Anyone authenticated can read their own doc during login
      allow read: if request.auth != null;
      // First login can create own doc
      allow create: if request.auth != null && request.auth.uid == userId;
      // Only admin can update roles/status; user can update their own profile fields
      allow update: if isAdmin() ||
                       (request.auth.uid == userId &&
                        !("role" in request.resource.data.diff(resource.data).affectedKeys()) &&
                        !("status" in request.resource.data.diff(resource.data).affectedKeys()));
      // Only admin can delete
      allow delete: if isAdmin();
    }

    // Pre-registered users
    match /preRegistered/{docId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    // Events (parent collection)
    match /events/{eventId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "spoc";

      // Sub-collections under event
      match /{subCollection}/{docId} {
        allow read: if isApproved();
        allow create, update, delete: if canEdit();
      }

      // Crowd config
      match /crowd/{configId} {
        allow read: if isApproved();
        allow write: if canEdit();
      }
    }
  }
}
